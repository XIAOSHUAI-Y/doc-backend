generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model YjsDocument {
  id        String      @id @default(uuid())
  docId     String      @unique
  name      String?
  updates   YjsUpdate[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model YjsUpdate {
  id        String      @id @default(uuid())
  docId     String
  update    Bytes
  version   Int         @default(0)
  createdAt DateTime    @default(now())

  document  YjsDocument @relation(fields: [docId], references: [docId], onDelete: Cascade)
  @@index([docId, version])
}
